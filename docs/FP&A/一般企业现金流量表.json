  "field_definitions": {
    "amount_fields": [
      "sales_goods_services",
      "tax_refunds",
      "other_operating_inflows",
      "purchase_goods_services",
      "employee_payments",
      "tax_payments",
      "other_operating_outflows",
      "investment_recovery",
      "investment_income",
      "asset_disposal",
      "fixed_asset_purchase",
      "investment_payments",
      "equity_investment",
      "debt_borrowing",
      "debt_repayment",
      "dividend_interest_payments"
    ],
    "calculated_fields": [
      "operating_activities_net",
      "investing_activities_net",
      "financing_activities_net",
      "cash_net_increase",
      "ending_cash_balance"
    ]
  },
  "validation_rules": {
    "required_fields": [
      "company_name",
      "report_period",
      "currency_unit"
    ],
    "calculation_rules": {
      "operating_net": "SUM(operating_inflows) - SUM(operating_outflows)",
      "investing_net": "SUM(investing_inflows) - SUM(investing_outflows)",
      "financing_net": "SUM(financing_inflows) - SUM(financing_outflows)",
      "cash_net_increase": "operating_net + investing_net + financing_net",
      "ending_balance": "opening_balance + cash_net_increase"
    }
  },
  "usage_notes": [
    "本模板适用于一般企业的现金流量表编制",
    "所有金额项目需填写具体数值，单位为指定货币",
    "计算项目由系统自动计算，无需手动填写",
    "请确保期初余额与上期期末余额一致",
    "现金流量分类需符合企业会计准则要求"
  ]
